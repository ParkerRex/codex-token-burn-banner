{
  "name": "codex-token-burn-banner",
  "version": "0.1.0",
  "description": "Generate and optionally upload an X profile banner showing daily Codex token burn.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "token-burn-banner": "./src/index.js"
  },
  "scripts": {
    "once": "node src/index.js once",
    "render": "node src/index.js render",
