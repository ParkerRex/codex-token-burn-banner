# X API OAuth 1.0a user-context credentials.
# Create these in the X Developer Portal with write access.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Also accepted for compatibility with the worker repo:
# X_POSTING_API_KEY=
# X_POSTING_API_SECRET=
# X_POSTING_ACCESS_TOKEN=
# X_POSTING_ACCESS_TOKEN_SECRET=

# Optional overrides.
# CODEX_HOME=/Users/you/.codex
# CODEXBAR_BIN=/opt/homebrew/bin/codexbar
# X_API_BASE_URL=https://api.x.com
# X_UPLOAD_BASE_URL=https://upload.twitter.com
